# ------------------------------
# 轻壳正式环境配置模板
# ------------------------------

# 壳应用远端地址（Capacitor server.url 同步使用）
NEXT_PUBLIC_APP_SHELL_URL=https://app.guoxueyun.com

# API 网关地址（段子、业务接口）
NEXT_PUBLIC_API_BASE_URL=https://api.guoxueyun.com

# AI 网关地址（模型推理服务）
NEXT_PUBLIC_AI_API_BASE_URL=https://ai.guoxueyun.com

# 资源服务地址（静态资源/CDN）
NEXT_PUBLIC_RESOURCE_BASE_URL=https://res.guoxueyun.com

# 段子批量生成接口路径
NEXT_PUBLIC_DUANZI_BATCH_API_PATH=/api/v1/duanzi/batch-generate

# 资源模式：bundled=本地兜底，remote=优先远端
NEXT_PUBLIC_REMOTE_RESOURCE_MODE=remote

# 本地缓存前缀，不同环境建议使用不同前缀
NEXT_PUBLIC_OFFLINE_CACHE_PREFIX=guoxue-cache-prod

# 是否启用加密资源标记（仅开关，不放解密密钥）
NEXT_PUBLIC_ENABLE_ENCRYPTED_RESOURCES=true

# 客户端鉴权令牌（仅低权限调用，严禁填服务端主密钥）
NEXT_PUBLIC_API_AUTH_TOKEN=
NEXT_PUBLIC_AI_AUTH_TOKEN=

# 请求韧性参数（超时/重试/限流）
NEXT_PUBLIC_API_TIMEOUT_MS=12000
NEXT_PUBLIC_API_RETRY_TIMES=2
NEXT_PUBLIC_API_RATE_LIMIT_PER_MINUTE=50

# 易学商用内核配置
NEXT_PUBLIC_BAZI_ENGINE=yuanfenju
NEXT_PUBLIC_BAZI_RULESET=liuwenyuan-v1
NEXT_PUBLIC_YUANFENJU_API_BASE_URL=https://api.yuanfenju.com
NEXT_PUBLIC_YUANFENJU_API_KEY=

# 仅服务端使用：不要以 NEXT_PUBLIC_ 前缀暴露到客户端
SERVER_RESOURCE_SIGNING_KEY=
SERVER_AI_GATEWAY_SECRET=
SERVER_INTERNAL_WEBHOOK_SECRET=

# 客户端可在运行时通过本地存储覆盖服务地址（示例键名）
# RUNTIME_API_BASE_URL=
# RUNTIME_RESOURCE_BASE_URL=
